class RolesDialog(QDialog):
    """
    Simple dialog to add / remove / edit employee types and their hourly cost.
    Returns a dict {role_name: cost} when accepted.
    """
    def __init__(self, parent, roles):
        super().__init__(parent)
        self.setWindowTitle("Gérer les rôles")
        self.resize(380, 320)
        self.roles = dict(roles)  # copy

        layout = QVBoxLayout(self)
        self.listw = QListWidget()
        layout.addWidget(self.listw)

        self._refresh_list()

        btns_layout = QHBoxLayout()
        self.btn_add = QPushButton("Ajouter")
        self.btn_edit = QPushButton("Modifier coût")
        self.btn_rename = QPushButton("Renommer")
        self.btn_remove = QPushButton("Supprimer")
        btns_layout.addWidget(self.btn_add)
        btns_layout.addWidget(self.btn_edit)
        btns_layout.addWidget(self.btn_rename)
        btns_layout.addWidget(self.btn_remove)
        layout.addLayout(btns_layout)

        box = QDialogButtonBox(QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        layout.addWidget(box)

        self.btn_add.clicked.connect(self._on_add)
        self.btn_remove.clicked.connect(self._on_remove)
        self.btn_edit.clicked.connect(self._on_edit_cost)
        self.btn_rename.clicked.connect(self._on_rename)
        box.accepted.connect(self.accept)
        box.rejected.connect(self.reject)

    def _refresh_list(self):
        self.listw.clear()
        for r, c in sorted(self.roles.items()):
            it = QListWidgetItem(f"{r} — {float(c):.2f} Dinars/h")
            it.setData(Qt.ItemDataRole.UserRole, r)
            self.listw.addItem(it)

    def _on_add(self):
        name, ok = QInputDialog.getText(self, "Nouveau rôle", "Nom du rôle :")
        if not ok or not name.strip():
            return
        name = name.strip()
        if name in self.roles:
            QMessageBox.warning(self, "Erreur", "Rôle déjà existant.")
            return
        cost, ok2 = QInputDialog.getDouble(self, "Coût horaire", f"Coût pour '{name}' (Dinars/h):", 10.0, 0.0, 100000.0, decimals=2)
        if not ok2:
            return
        self.roles[name] = cost
        self._refresh_list()

    def _on_remove(self):
        it = self.listw.currentItem()
        if not it:
            return
        name = it.data(Qt.ItemDataRole.UserRole)
        resp = QMessageBox.question(self, "Supprimer", f"Supprimer le rôle '{name}' ?")
        if resp == QMessageBox.StandardButton.Yes:
            self.roles.pop(name, None)
            self._refresh_list()

    def _on_edit_cost(self):
        it = self.listw.currentItem()
        if not it:
            return
        name = it.data(Qt.ItemDataRole.UserRole)
        cur = self.roles.get(name, 0)
        cost, ok = QInputDialog.getDouble(self, "Modifier coût", f"Coût horaire pour '{name}' (Dinars/h):", float(cur), 0.0, 100000.0, decimals=2)
        if not ok:
            return
        self.roles[name] = cost
        self._refresh_list()

    def _on_rename(self):
        it = self.listw.currentItem()
        if not it:
            return
        old = it.data(Qt.ItemDataRole.UserRole)
        new, ok = QInputDialog.getText(self, "Renommer rôle", "Nouveau nom :", text=old)
        if not ok or not new.strip():
            return
        new = new.strip()
        if new in self.roles and new != old:
            QMessageBox.warning(self, "Erreur", "Un rôle avec ce nom existe déjà.")
            return
        self.roles[new] = self.roles.pop(old)
        self._refresh_list()

    def get_roles(self):
        return dict(self.roles)


class StartDialog(QDialog):
    """
    Initial dialog shown at app start. Allows setting commerce name and editing roles.
    On accept returns chosen commerce_name and roles dict.
    """
    def __init__(self, parent=None, commerce_name="Supermarché", roles=None):
        super().__init__(parent)
        self.setWindowTitle("Configuration initiale")
        self.resize(520, 320)
        # apply shared theme to this dialog
        try:
            apply_dark_theme(self)
        except Exception:
            # best-effort: ignore theme errors
            pass
        self._roles = dict(roles or {"vendeur": 10, "caissier": 11, "securite": 9})
        self._commerce_name = commerce_name

        layout = QVBoxLayout(self)

        lbl = QLabel("Définissez le nom du commerce et les types d'employés avant de continuer")
        lbl.setWordWrap(True)
        layout.addWidget(lbl)

        name_row = QHBoxLayout()
        name_row.addWidget(QLabel("Nom du commerce:"))
        self.name_edit = QLineEdit(self._commerce_name)
        name_row.addWidget(self.name_edit)
        layout.addLayout(name_row)

        layout.addWidget(QLabel("Rôles actuels:"))
        self.roles_list = QListWidget()
        layout.addWidget(self.roles_list, stretch=1)
        self._refresh_roles_list()

        btns_row = QHBoxLayout()
        self.btn_edit_roles = QPushButton("Gérer rôles...")
        self.btn_edit_roles.clicked.connect(self._open_roles_dialog)
        btns_row.addWidget(self.btn_edit_roles)
        btns_row.addStretch()
        layout.addLayout(btns_row)

        box = QDialogButtonBox(QDialogButtonBox.StandardButton.Ok | QDialogButtonBox.StandardButton.Cancel)
        box.accepted.connect(self.accept)
        box.rejected.connect(self.reject)
        layout.addWidget(box)

    def _refresh_roles_list(self):
        self.roles_list.clear()
        for r, c in sorted(self._roles.items()):
            it = QListWidgetItem(f"{r} — {float(c):.2f} Dinars/h")
            it.setData(Qt.ItemDataRole.UserRole, r)
            self.roles_list.addItem(it)

    def _open_roles_dialog(self):
        dlg = RolesDialog(self, self._roles)
        if dlg.exec() == QDialog.DialogCode.Accepted:
            new = dlg.get_roles()
            if not new:
                QMessageBox.warning(self, "Rôles", "Il faut au moins un rôle.")
                return
            self._roles = new
            self._refresh_roles_list()

    def accept(self) -> None:
        name = self.name_edit.text().strip()
        if not name:
            QMessageBox.warning(self, "Nom requis", "Entrez un nom pour le commerce.")
            return
        if not self._roles:
            QMessageBox.warning(self, "Rôles requis", "Définissez au moins un rôle.")
            return
        self._commerce_name = name
        super().accept()

    def get_values(self):
        return self._commerce_name, dict(self._roles)


