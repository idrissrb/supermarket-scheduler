        grp_constraints.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)
        grp_actions.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)

