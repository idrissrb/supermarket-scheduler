                font-family: "Segoe UI", Roboto, Arial, sans-serif;
                color: #E6EEF8;
                background: #0f1720;
            }
            QGroupBox {
                background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #0b1114, stop:1 #0f1418);
                border: 1px solid #1f2a30;
